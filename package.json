{
  "name": "discord-voice-announcer",
  "version": "1.0.0",
  "description": "Discord bot that announces when users join or leave voice channels via TTS",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx --watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "keywords": [
    "discord",
    "bot",
    "voice",
    "tts",
    "announcer"
  ],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.33.0",
  "dependencies": {
    "@discordjs/opus": "^0.10.0",
    "@discordjs/voice": "^0.19.2",
    "discord.js": "^14.26.4",
    "dotenv": "^17.4.2",
    "ffmpeg-static": "^5.3.0",
    "google-tts-api": "^2.0.2"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@discordjs/opus",
      "ffmpeg-static",
      "esbuild"
    ]
  }
}
